# Copy to .env and fill in. Never commit .env.
# Missing keys are fine: the run degrades gracefully and marks skipped providers.

# --- US providers ---
OPENAI_API_KEY=<your-openai-key>       # gpt-image-1 + GPT-4o judge
GEMINI_API_KEY=<your-google-key>       # Imagen 4 Fast
ANTHROPIC_API_KEY=<your-anthropic-key> # Pipeline B brains (Opus 4.8 / Sonnet 5)

# --- Chinese reasoning brains (Pipeline C) ---
ZAI_API_KEY=<your-zai-glm-key>         # GLM-5.2 / GLM-4.7  (no clean substitute)

# --- Chinese image models (default route: fal.ai aggregator) ---
FAL_KEY=<your-fal-key>                 # Seedream + Qwen-Image + optional Qwen-VL judge

# --- Optional native Chinese routes (stretch; provenance purity) ---
DASHSCOPE_API_KEY=<optional-alibaba-key>   # native Qwen-Image / Qwen-VL
BYTEPLUS_API_KEY=<optional-byteplus-key>   # native Seedream

# --- Optional neutral third judge ---
OPENROUTER_API_KEY=<optional-openrouter-key>  # Pixtral / Llama-Vision neutral judge
